# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file to GitHub!

# ─── ThingSpeak Configuration ───────────────────────────────
THINGSPEAK_API_KEY=YOUR_THINGSPEAK_WRITE_API_KEY_HERE
THINGSPEAK_CHANNEL_ID=YOUR_CHANNEL_ID_HERE
THINGSPEAK_READ_API_KEY=YOUR_THINGSPEAK_READ_API_KEY_HERE

# ─── Blynk Configuration ────────────────────────────────────
BLYNK_AUTH_TOKEN=YOUR_BLYNK_AUTH_TOKEN_HERE

# ─── MQTT Broker Configuration ──────────────────────────────
MQTT_BROKER=broker.hivemq.com
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=smart_agriculture/farm_1

# ─── Alert Configuration ────────────────────────────────────
ALERT_EMAIL=your_email@example.com
ALERT_PHONE=+91XXXXXXXXXX
